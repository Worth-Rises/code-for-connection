# Database
# See docker-compose.yml for default values
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://openconnect:hackathon2026@localhost:5432/openconnect

# Redis
REDIS_URL=redis://localhost:6379

# Signaling Server
SIGNALING_URL=http://localhost:3001

# Authentication
JWT_SECRET=changeme
JWT_EXPIRES_IN=24h

# Twilio (provided at hackathon)
TWILIO_ACCOUNT_SID=changeme
TWILIO_AUTH_TOKEN=changeme
TWILIO_PHONE_NUMBER=changeme

# Server
PORT=3000
NODE_ENV=development

# Test mode — bypasses time validation, enables POST /api/video/test/create-call (instant calls)
TEST_MODE=true
VITE_TEST_MODE=true

# When true, all video call requests go to admin pending queue (even for approved contacts)
# When false, approved contacts auto-schedule without admin approval
ADMIN_APPROVAL_REQUIRED=true
