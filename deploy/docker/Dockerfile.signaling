# Signaling Server
# Socket.IO server for real-time call events (join, leave, mute, etc.)
# Connects to Redis for coordinating across multiple instances

FROM node:20-alpine AS builder
WORKDIR /app
COPY services/signaling/package*.json ./
RUN npm ci
COPY services/signaling/ .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
COPY --from=builder /app .
EXPOSE 3001
CMD ["node", "dist/index.js"]
