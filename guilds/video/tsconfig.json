{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": ["api/**/*", "ui/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
