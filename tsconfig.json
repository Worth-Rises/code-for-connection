{
  "compilerOptions": {
    "jsx": "react",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@openconnect/shared/*": ["packages/shared/src/*"],
      "@openconnect/ui/*": ["packages/ui/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/dist"]
}
